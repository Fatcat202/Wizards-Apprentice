
// Used to reset all element related platform variables when swapping between elements

function scr_element_reset_variables()
{
	is_steaming = false;
	steam_spawned = false;
	is_flaming = false;
	flames_spawned = false
	freeze_timer = 0
	spreading_fire_timer = 0
	melting_ice_timer = 0
	evaporation_timer = 0
	interacting = false
}