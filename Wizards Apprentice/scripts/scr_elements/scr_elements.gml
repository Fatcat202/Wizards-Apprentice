
function scr_elements()
{
	// Provides the logic for changing enviormental element
	
	
	// Used for own variables
	var own_element
	var own_level
	var own_id
	
	// Used for calling other elements variables
	var other_element
	var other_level
	var other_id

	
	// Cancel script if either effect has no element
	if(other_element == "None" || own_element == "None") exit;
	
	
	
	
	
}